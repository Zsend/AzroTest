/* Final philosophy hero accent lock: add the AZRO accent line and divider
   without disturbing the settled button position or the rest of the site. */

:root{
  --philosophy-hero-divider: linear-gradient(90deg,
    rgba(193,214,255,.30) 0%,
    rgba(193,214,255,.14) 62%,
    rgba(193,214,255,0) 100%);
}

.philosophy-page .hero-copy-stack--philosophy > .lede{
  position: relative !important;
  overflow: visible !important;
}

.philosophy-page .hero-copy-stack--philosophy > .lede::before,
.philosophy-page .hero-copy-stack--philosophy > .lede::after{
  content: "" !important;
  position: absolute !important;
  left: 0 !important;
  pointer-events: none !important;
}

@media (min-width: 981px){
  .philosophy-page .hero-copy-stack--philosophy > .lede::before{
    top: -28px !important;
    width: 74px !important;
    height: 3px !important;
    border-radius: 999px !important;
    background: var(--azro-accent-line-short) !important;
    box-shadow: 0 0 18px rgba(112,152,255,.18) !important;
    opacity: .98 !important;
  }

  .philosophy-page .hero-copy-stack--philosophy > .lede::after{
    bottom: -14px !important;
    width: min(100%, 30rem) !important;
    height: 1px !important;
    background: var(--philosophy-hero-divider) !important;
    opacity: .98 !important;
  }
}

@media (max-width: 980px){
  .philosophy-page .hero-copy-stack--philosophy > .lede::before{
    top: -24px !important;
    width: 68px !important;
    height: 3px !important;
    border-radius: 999px !important;
    background: var(--azro-accent-line-short) !important;
    box-shadow: 0 0 16px rgba(112,152,255,.18) !important;
    opacity: .98 !important;
  }

  .philosophy-page .hero-copy-stack--philosophy > .lede::after{
    bottom: -12px !important;
    width: min(100%, 24rem) !important;
    height: 1px !important;
    background: var(--philosophy-hero-divider) !important;
    opacity: .98 !important;
  }
}
